#PKG_CXXFLAGS = -I"$(R_HOME)/include" $(SHLIB_OPENMP_CXXFLAGS)
#PKG_LIBS = -L"$(R_HOME)/bin/x64" $(SHLIB_OPENMP_CXXFLAGS) -lz
ZLIB_CFLAGS := $(shell "${R_HOME}/bin/R" --vanilla --slave -e "cat(zlibbioc::pkgconfig('PKG_CFLAGS'))")
ZLIB_LIBDIR := $(shell "${R_HOME}/bin/R" --vanilla --slave -e "cat(system.file('libs/x64', package='zlibbioc'))")

PKG_CPPFLAGS += -Iexternal -Iexternal/simdutf $(ZLIB_CFLAGS)
PKG_CXXFLAGS += -std=c++17

# Source files from different directories
SOURCES = $(wildcard *.cpp)
SOURCES += external/simdutf_wrapper.cpp
SOURCES += $(wildcard project/*.cpp)
SOURCES += $(wildcard nts/*.cpp)
SOURCES += $(wildcard mass_spec/*.cpp)

# Exclude simdutf source files from compilation when not using the wrapper
# (we compile the bundled simdutf via external/simdutf_wrapper.cpp)
SOURCES := $(filter-out external/simdutf/simdutf.cpp external/simdutf/amalgamation_demo.cpp, $(SOURCES))

OBJECTS = $(SOURCES:.cpp=.o)

# Compile simdutf_wrapper without pedantic warnings (third-party code)
#simdutf_wrapper.o: simdutf_wrapper.cpp
#	$(CXX) $(ALL_CPPFLAGS) $(ALL_CXXFLAGS) -Wno-pedantic -c $< -o $@

RHDF5_LIBS = $(shell "$(R_HOME)/bin${R_ARCH_BIN}/Rscript" -e 'Rhdf5lib::pkgconfig("PKG_CXX_LIBS")')

PKG_CXXFLAGS += $(SHLIB_OPENMP_CXXFLAGS)
PKG_LIBS += $(SHLIB_OPENMP_CXXFLAGS) $(RHDF5_LIBS) -L$(ZLIB_LIBDIR) -lzbioc

# DuckDB (vendored cross-platform) - use vendored copy under src/external/duckdb
PKG_CPPFLAGS += -Iexternal/duckdb/linux/
PKG_LIBS += -Lexternal/duckdb/linux/ -lduckdb
